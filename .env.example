# ─────────────────────────────────────────────────────────────────────────────
# Onyx Base — environment template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` (which is gitignored) and fill in real values:
#
#   cp .env.example .env
#
# NEVER commit `.env`. It contains your Telegram bot token, your admin key,
# and your signing secret — anyone with these can read all stored data and
# impersonate the admin.
# ─────────────────────────────────────────────────────────────────────────────

# SQLite database location (file-based Prisma datasource).
DATABASE_URL=file:/home/z/my-project/db/custom.db

# ─── Telegram server-side storage layer ─────────────────────────────────────
# Used AUTOMATICALLY for file uploads (and KV/event mirroring) when a user has
# NOT set up their own custom Telegram chat ID + bot token in Settings.
#
# We STRONGLY encourage you to create your own Telegram bot (via @BotFather)
# and your own channel — that way your data lives in YOUR Telegram account,
# giving you unlimited free storage that only you control.
TELEGRAM_BOT_TOKEN=0000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
TELEGRAM_CHAT_ID=-1000000000000

# ─── Internal signing secret ────────────────────────────────────────────────
# Used to (a) mint API keys and (b) sign time-limited download tokens.
# Generate with:  openssl rand -hex 32
CLOUDKV_SECRET=replace_with_a_long_random_hex_string

# ─── Bootstrap admin key ────────────────────────────────────────────────────
# The one irrevocable admin key for this instance. MUST start with `onyxbase_`.
# Generate the suffix with:  openssl rand -hex 16
# Then sign in at /admin with the full string `onyxbase_<that_suffix>`.
BOOTSTRAP_ADMIN_KEY=onyxbase_replace_with_your_own_random_suffix

# ─── Optional: public-facing Telegram handles (shown in the in-app docs) ────
# These are NOT secrets — they're just the bot username / channel name shown to
# users in the dashboard's "Docs" tab. Leave blank to show generic placeholders.
NEXT_PUBLIC_TELEGRAM_BOT_HANDLE=your_bot
NEXT_PUBLIC_TELEGRAM_CHANNEL_NAME=your-channel
NEXT_PUBLIC_TELEGRAM_CHANNEL_HANDLE=your_channel

# ─── Email OTP delivery ──────────────────────────────────────────────────────
# Used to deliver email verification codes for signup / login / password reset.
#
# FOUR provider modes, tried in priority order:
#
#   1. Gmail OAuth2 XOAUTH2  (your regular Gmail — NO App Password)  ★ BEST
#      Sign in once with your Gmail password via Google's OAuth2 consent
#      screen. The system persists a refresh token and auto-sends OTP emails
#      through smtp.gmail.com. 500 emails/day free (2000/day Workspace).
#
#      Setup (one-time, ~5 minutes):
#        a. Go to https://console.cloud.google.com/ → create a project (free)
#        b. Enable the Gmail API (APIs & Services → Library → "Gmail API")
#        c. OAuth consent screen: User type = External, add YOUR Gmail as a
#           Test User (so the app stays in Testing mode — no verification)
#        d. Credentials → Create → OAuth client ID → Web application
#           Authorized redirect URI: <your-public-url>/api/admin/gmail/callback
#           (the admin Email tab shows the exact URI to copy)
#        e. Copy Client ID + Client Secret into the vars below
#        f. Open admin dashboard → Email tab → "Connect Gmail"
#           Sign in with your REGULAR Gmail password (no App Password!)
#           Approve access. Done — OTPs auto-send forever.
#
#   2. SMTP plain  (your own credentials)
#      Set SMTP_HOST + SMTP_USER + SMTP_PASS (SMTP_PORT + SMTP_FROM optional).
#      Works with ANY SMTP provider. Brevo is recommended for a free setup:
#        • Brevo    — 300 emails/day FREE, no credit card → https://brevo.com
#        • SendGrid — 100 emails/day free
#        • Mailgun  — 5 000/month free (3 months)
#        • Your own mail server — truly unlimited
#
#   3. Resend HTTP API  (100 emails/day free)
#      Set RESEND_API_KEY + RESEND_FROM.
#      A single API key + one HTTP POST. Sign up at https://resend.com.
#
#   4. Local dev mode  (NO credentials — truly unlimited free)  [fallback]
#      Leave ALL email env vars unset. The 6-digit code is returned as
#      `devCode` in the API response AND logged to the server console AND
#      surfaced inline in the UI. Works fully offline.
#
# Priority:  Gmail-OAuth2  >  SMTP  >  Resend  >  Dev mode

# ── Gmail OAuth2 (recommended — no App Password) ──
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
# Where to persist the refresh token (default: /home/z/my-project/.gmail-tokens.json)
GMAIL_TOKEN_FILE=

# ── SMTP plain (Brevo / your own server) ──
# Example (Brevo):
#   SMTP_HOST=smtp-relay.brevo.com
#   SMTP_PORT=587
#   SMTP_USER=you@example.com
#   SMTP_PASS=<brevo SMTP key>
#   SMTP_FROM="Onyx Base <you@example.com>"
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Resend HTTP API ──
# Example:
#   RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
#   RESEND_FROM="Onyx Base <onboarding@resend.dev>"
RESEND_API_KEY=
RESEND_FROM=

# App name shown in the OTP email subject / body. Defaults to "Onyx Base".
NEXT_PUBLIC_APP_NAME=Onyx Base

# ─── Required for password reset: signing secret for short-lived reset tokens ─
# When a user verifies an OTP for purpose='reset', we mint a 10-minute signed
# token they must include in the /api/auth/reset-password call. This secret
# signs that token. Generate with:  openssl rand -hex 32
# In dev mode (email API unset), reset still works end-to-end via the devCode
# path, so a non-empty value here is REQUIRED for the reset flow to function.
RESET_PASSWORD_SECRET=onyx_base_dev_reset_secret_change_me
