# ─────────────────────────────────────────────────────────────────────────────
# Onyx Base — environment template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` (which is gitignored) and fill in real values:
#
#   cp .env.example .env
#
# NEVER commit `.env`. It contains your Telegram bot token, your admin key,
# and your signing secret — anyone with these can read all stored data and
# impersonate the admin.
# ─────────────────────────────────────────────────────────────────────────────

# SQLite database location (file-based Prisma datasource).
DATABASE_URL=file:/home/z/my-project/db/custom.db

# ─── Telegram server-side storage layer ─────────────────────────────────────
# Used AUTOMATICALLY for file uploads (and KV/event mirroring) when a user has
# NOT set up their own custom Telegram chat ID + bot token in Settings.
#
# We STRONGLY encourage you to create your own Telegram bot (via @BotFather)
# and your own channel — that way your data lives in YOUR Telegram account,
# giving you unlimited free storage that only you control.
TELEGRAM_BOT_TOKEN=0000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
TELEGRAM_CHAT_ID=-1000000000000

# ─── Internal signing secret ────────────────────────────────────────────────
# Used to (a) mint API keys and (b) sign time-limited download tokens.
# Generate with:  openssl rand -hex 32
CLOUDKV_SECRET=replace_with_a_long_random_hex_string

# ─── Bootstrap admin key ────────────────────────────────────────────────────
# The one irrevocable admin key for this instance. MUST start with `onyxbase_`.
# Generate the suffix with:  openssl rand -hex 16
# Then sign in at /admin with the full string `onyxbase_<that_suffix>`.
BOOTSTRAP_ADMIN_KEY=onyxbase_replace_with_your_own_random_suffix

# ─── Optional: public-facing Telegram handles (shown in the in-app docs) ────
# These are NOT secrets — they're just the bot username / channel name shown to
# users in the dashboard's "Docs" tab. Leave blank to show generic placeholders.
NEXT_PUBLIC_TELEGRAM_BOT_HANDLE=your_bot
NEXT_PUBLIC_TELEGRAM_CHANNEL_NAME=your-channel
NEXT_PUBLIC_TELEGRAM_CHANNEL_HANDLE=your_channel
