// Onyx Base — Telegram-backed key-value developer platform
// SQLite is used as a fast index/cache; Telegram chat is the durable backup.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(cuid())
  userId      String    @unique // public id, e.g. usr_8d72a
  name        String?
  email       String?
  plan        String    @default("free") // free | pro | team
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  apiKeys     ApiKey[]
  records     Record[]
  collections Collection[]
  logs        Log[]
}

model ApiKey {
  id         String    @id @default(cuid())
  key        String    @unique // kv_live_xxxxxxxxx
  name       String    @default("default")
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revoked    Boolean   @default(false)

  @@index([userId])
}

model Collection {
  id        String   @id @default(cuid())
  name      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  records   Record[]
  createdAt DateTime @default(now())

  @@unique([userId, name])
  @@index([userId])
}

model Record {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  collectionId       String
  collection         Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  key                String
  value              String // JSON-encoded value
  valueType          String   @default("string") // string|number|boolean|object|array
  telegramMessageId  Int?     // reference to the backup message in Telegram
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([collectionId, key])
  @@index([userId])
  @@index([collectionId, key])
}

model Log {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String   // set|get|delete|login|apikey.create|apikey.revoke|export|...
  key       String?
  detail    String?
  source    String   @default("api") // api|cli|dashboard|system
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ─── Named, server-defined projections over a collection ────────────────────
// A "view" stores { collection, projection (columns), filter (WHERE clause) }
// and executing it returns the matching records for the owning user. The
// `userId` is the dbUserId from the data-store (mirrors Record.userId).
model View {
  id          Int      @id @default(autoincrement())
  userId      String
  name        String
  collection  String
  projection  String   // comma-separated column list, "*" = all
  filter      String?  // optional WHERE clause on key/value (best-effort)
  createdAt   DateTime @default(now())

  @@unique([userId, name])
  @@index([userId])
}

// ─── Server-side JS handlers (PL/pgSQL equivalent) ─────────────────────────
// Functions store user-defined JS code as a string. When triggered they run
// in a sandboxed `new Function('ctx', code)` context with access to a
// restricted context object { record, db, user }.
model Function {
  id        Int      @id @default(autoincrement())
  userId    String
  name      String
  code      String
  trigger   String   @default("manual") // manual | set | delete | ...
  createdAt DateTime @default(now())

  @@unique([userId, name])
  @@index([userId])
}

// ─── Pre-computed aggregations (Materialized Views) ────────────────────────
// Stores a SELECT query, runs it on create/refresh, and caches the JSON
// result. Reading is O(1) — no query execution at read time.
model MaterializedView {
  id              Int      @id @default(autoincrement())
  userId          String
  name            String
  query           String   // SQL (executed via the user-scoped SQL Editor engine)
  result          String   // JSON-encoded cached result
  lastRefreshedAt DateTime
  createdAt       DateTime @default(now())

  @@unique([userId, name])
  @@index([userId])
}

// ─── Account-scoped custom tables (CREATE TABLE manager) ────────────────────
// Each developer can create their own SQL tables. The metadata (owner,
// display name, real SQLite table name, access mode, column schema) lives
// here; the actual table lives in SQLite as `usr_<shortHash>_<name>` so two
// developers can both own a table called "notes" without colliding.
//
// accessMode controls what the PUBLIC v1 API may do with the table's rows:
//   read      — SELECT only
//   write     — INSERT / UPDATE / DELETE only (no reads)
//   readwrite — both
// The dashboard owner can always do everything regardless of accessMode.
model UserTable {
  id         String   @id @default(cuid())
  userId     String   // dbUserId (owner) — never the public usr_ id
  name       String   // user-facing name (no usr_ prefix), e.g. "notes"
  tableName  String   // real SQLite table name, e.g. "usr_notes_a1b2c3d4"
  accessMode String   @default("readwrite") // read | write | readwrite
  schema     String   // JSON: [{name, type, primary, autoIncrement, nullable, defaultValue}]
  rowCount   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, name])
  @@unique([tableName])
  @@index([userId])
}
